<Window x:Class="Kalendarz.Views.AddEditStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Kalendarz.Helpers"
        mc:Ignorable="d"
        Title="Dodaj/Edytuj ucznia" Height="550" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBackgroundConverter}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Imię:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="1" Text="Nazwisko:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="1" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="2" Text="Ostatni temat:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="2" Text="{Binding LastTopic, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="3" Text="Nazwa Discord:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="3" Text="{Binding DiscordName, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="4" Text="Klasa:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="4" Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="5" Text="Opłacone godziny:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="5" Text="{Binding PaidHours, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="6" Text="Cena za godzinę (zł):" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox Grid.Row="6" Text="{Binding HourlyRate, UpdateSourceTrigger=PropertyChanged}" Margin="0,20,0,10" />

        <TextBlock Grid.Row="7" Text="Status:" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <ComboBox Grid.Row="7" Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" Margin="0,20,0,10">
            <ComboBoxItem Content="AKTYWNY" />
            <ComboBoxItem Content="NIEAKTYWNY" />
        </ComboBox>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Click="Ok_Click" Width="80" Margin="0,0,10,0" Padding="5"
                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
            <Button Content="Anuluj" Click="Cancel_Click" Width="80" Padding="5"
                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
        </StackPanel>
    </Grid>
</Window>
