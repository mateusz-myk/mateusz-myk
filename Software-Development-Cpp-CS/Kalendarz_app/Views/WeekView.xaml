<UserControl x:Class="Kalendarz.Views.WeekView" x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:Kalendarz.Converters"
    xmlns:helpers="clr-namespace:Kalendarz.Helpers"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800"
    Focusable="True"
    KeyDown="UserControl_KeyDown"
    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBackgroundConverter}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button Content="Powrót" Command="{Binding BackCommand}"
                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
            <TextBlock Text="  " />
            <TextBlock Text="{Binding Plan.Name}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                       Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />

            <!-- Przyciski przełączania planów i data — po prawej stronie -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding DataContext.Plans, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Margin="4,0,0,0" Padding="8,4"
                                    Command="{Binding DataContext.SwitchPlanCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,4,0">
                    <TextBlock x:Name="TodayLabel" FontWeight="SemiBold"
                               Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
                    <TextBlock Text=", "
                               Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
                    <TextBlock x:Name="CurrentTimeLabel" FontWeight="SemiBold"
                               Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <!-- Siatka tygodniowa z blokami zajęć na Canvasie -->
        <Border Grid.Row="1" BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" BorderThickness="1" Padding="8"
                Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeSecondaryBackgroundConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" /> <!-- etykiety godzin -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" /> <!-- panel notatek po prawej - auto width -->
                </Grid.ColumnDefinitions>

                <!-- POPRAWKA: Grid zamiast StackPanel, żeby ScrollViewer rozciągał się na całą wysokość -->
                <Grid x:Name="ContentStack" Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,8">
                            <Button Content="Dodaj zajęcia" Command="{Binding AddZajecieCommand}" Width="100" Margin="0,0,6,0"
                                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                            <Button Content="W" Command="{Binding ClearAllCommand}" Width="28" Height="28" 
                                    FontWeight="Bold" FontSize="14" ToolTip="Wyczyść wszystko (wymaga PIN)"
                                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                        </StackPanel>
                        <TextBlock Text="Poniedziałek - Niedziela, godz. 7:00 - 22:00" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Grid PreviewMouseRightButtonUp="ScheduleCanvas_MouseRightButtonUp">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="HourGrid" Grid.Column="0" />

                            <!-- Canvas z liniami siatki - ZIndex=0 (domyślny, najniżej) -->
                            <Canvas x:Name="ScheduleCanvas" Grid.Column="1" Background="#FFFFFFFF" Panel.ZIndex="0" />

                            <!-- Zajęcia - ZIndex=50 (w środku) -->
                            <ItemsControl x:Name="ZajeciaItemsControl" Grid.Column="1" ItemsSource="{Binding Zajecia}" Panel.ZIndex="50">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="{Binding ElementName=ScheduleCanvas, Path=Width}" Height="{Binding ElementName=ScheduleCanvas, Path=Height}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Resources>
                                    <!-- POPRAWKA: StartHour="7", TopOffset="28", ColumnOffsetCount="0" -->
                                    <converters:TimeToYConverter x:Key="TimeToY" StartHour="7" PixelsPerHour="48" TopOffset="28" />
                                    <converters:DurationToHeightConverter x:Key="DurationToHeight" PixelsPerHour="48" />
                                    <converters:DayToLeftSimpleConverter x:Key="DayToLeft" ColumnWidth="150" Padding="6" ColumnOffsetCount="0" />
                                    <converters:StringToBrushConverter x:Key="StringToBrush" />
                                </ItemsControl.Resources>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="1" BorderBrush="#FF666666" Background="{Binding Color, Converter={StaticResource StringToBrush}}" CornerRadius="4" Width="140" MouseLeftButtonDown="Block_MouseLeftButtonDown"
                                                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Edytuj" Click="ContextMenu_Edit_Click" />
                                                    <MenuItem Header="Usuń" Click="ContextMenu_Delete_Click" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <Border.ToolTip>
                                                <StackPanel MaxWidth="300" Margin="4">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                                    <TextBlock FontSize="12" Margin="0,6,0,0">
                                                        <Run Text="Dzień: " />
                                                        <Run Text="{Binding Day}" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="12">
                                                        <Run Text="Godz.: " />
                                                        <Run Text="{Binding StartString}" />
                                                        <Run Text=" - " />
                                                        <Run Text="{Binding EndString}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border.ToolTip>
                                            <Grid Margin="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap" />
                                                    <TextBlock FontSize="12">
                                                        <Run Text="{Binding StartString}" /> <Run Text=" - " /> <Run Text="{Binding EndString}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0" />
                                                </StackPanel>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Panel.ZIndex" Value="50" />
                                        <Setter Property="Canvas.Top">
                                            <Setter.Value>
                                                <Binding Path="Start" Converter="{StaticResource TimeToY}" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Left">
                                            <Setter.Value>
                                                <Binding Path="Day" Converter="{StaticResource DayToLeft}" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Height">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DurationToHeight}">
                                                    <Binding Path="Start" />
                                                    <Binding Path="End" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>

                            <!-- Canvas dla linii czasu - ZIndex=100 (najwyżej, nad wszystkim) -->
                            <Canvas x:Name="CurrentTimeCanvas" Grid.Column="1" Background="Transparent" IsHitTestVisible="False" Panel.ZIndex="100"
                                    Width="{Binding ElementName=ScheduleCanvas, Path=Width}" 
                                    Height="{Binding ElementName=ScheduleCanvas, Path=Height}" />
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <!-- Panel notatek po prawej - z możliwością zwijania -->
                <Grid Grid.Column="2" Margin="8,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Nagłówek z przyciskiem i napisem "Notatki" -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <!-- Przycisk do rozwijania/zwijania notatek - po prawej -->
                        <Button x:Name="ToggleNotesButton" Content="◀" 
                                Width="30" Height="30" FontSize="14" FontWeight="Bold"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                ToolTip="Rozwiń notatki" 
                                Click="ToggleNotesButton_Click"
                                Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                        <TextBlock Text="Notatki" FontWeight="Bold" FontSize="14" 
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   HorizontalAlignment="Right"
                                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
                    </DockPanel>

                    <!-- Panel notatek - domyślnie ukryty -->
                    <StackPanel x:Name="NotesPanel" Grid.Row="1" Width="420" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Text="{Binding NoteEditorText, UpdateSourceTrigger=PropertyChanged}" Width="220" Height="28" />
                            <Button Content="Dodaj" Command="{Binding AddNoteCommand}" Width="70" Margin="6,0,0,0"
                                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                        </StackPanel>
                        <!-- POPRAWKA: MouseDoubleClick dla edycji notatek -->
                        <ListBox x:Name="NotesListBox" ItemsSource="{Binding Notes}" SelectedItem="{Binding SelectedNote, Mode=TwoWay}" Margin="0,8,0,0" Height="400" MouseDoubleClick="NotesListBox_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <!-- display mode -->
                                        <DockPanel x:Name="DisplayPanel">
                                            <TextBlock Text="{Binding SerialNumber, StringFormat={}{0}.}" Width="30" />
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" MaxWidth="340" />
                                        </DockPanel>

                                        <!-- edit mode - wieloliniowy TextBox -->
                                        <StackPanel x:Name="EditPanel" Orientation="Vertical" Visibility="Collapsed">
                                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" 
                                                     Width="380" MinHeight="60" MaxHeight="150"
                                                     AcceptsReturn="True" TextWrapping="Wrap" 
                                                     VerticalScrollBarVisibility="Auto" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                                <Button Content="Zapisz" Command="{Binding DataContext.SaveNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="70" Margin="0,0,6,0"
                                                        Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                                        Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                                        BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                                                <Button Content="Anuluj" Command="{Binding DataContext.CancelEditNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="70"
                                                        Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                                                        Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                                                        BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="DisplayPanel" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="EditPanel" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                            <Button Content="Edytuj" Command="{Binding EditNoteCommand}" Width="70" Margin="0,0,6,0" />
                            <Button Content="Usuń" Command="{Binding DeleteNoteCommand}" Width="70" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
