<Window x:Class="Kalendarz.Views.EditDayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Kalendarz.Helpers"
        Title="Edytuj dzień" Height="320" Width="450" WindowStartupLocation="CenterScreen"
        Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBackgroundConverter}}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Data: " FontWeight="Bold"
                       Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
            <TextBlock x:Name="DateTextBlock" FontWeight="Normal"
                       Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Opis wydarzenia:" FontWeight="Bold" Margin="0,0,0,5"
                   Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
        <TextBox x:Name="DescriptionTextBox" Grid.Row="2" Height="80" TextWrapping="Wrap" 
                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" />

        <StackPanel Grid.Row="3" Margin="0,0,0,0">
            <TextBlock Text="Kolor tła:" FontWeight="Bold" Margin="0,0,0,8"
                       Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}" />
            <WrapPanel>
                <Button x:Name="BtnWhite" Content="Biały" Width="70" Height="35" Margin="2" Background="White" Click="ColorButton_Click" Tag="#FFFFFFFF" BorderBrush="Gray" BorderThickness="1" />
                <Button x:Name="BtnYellow" Content="Żółty" Width="70" Height="35" Margin="2" Background="Yellow" Click="ColorButton_Click" Tag="#FFFFFF00" BorderBrush="Gray" BorderThickness="1" />
                <Button x:Name="BtnGreen" Content="Zielony" Width="70" Height="35" Margin="2" Background="LightGreen" Click="ColorButton_Click" Tag="#FF90EE90" BorderBrush="Gray" BorderThickness="1" />
                <Button x:Name="BtnBlue" Content="Niebieski" Width="80" Height="35" Margin="2" Background="LightBlue" Click="ColorButton_Click" Tag="#FFADD8E6" BorderBrush="Gray" BorderThickness="1" />
                <Button x:Name="BtnPink" Content="Różowy" Width="70" Height="35" Margin="2" Background="Pink" Click="ColorButton_Click" Tag="#FFFFC0CB" BorderBrush="Gray" BorderThickness="1" />
            </WrapPanel>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Width="90" Height="35" IsDefault="True" Click="OK_Click" Margin="0,0,10,0"
                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
            <Button Content="Anuluj" Width="90" Height="35" IsCancel="True"
                    Background="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeButtonBackgroundConverter}}"
                    Foreground="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeForegroundConverter}}"
                    BorderBrush="{Binding Source={x:Static helpers:ThemeManager.Instance}, Path=IsDarkTheme, Converter={StaticResource ThemeBorderBrushConverter}}" />
        </StackPanel>
    </Grid>
</Window>
