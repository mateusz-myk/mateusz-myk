<Window x:Class="Kalendarz.Views.Dialogs.EditImageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edycja zdjęcia" Height="550" Width="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Ścieżka do zdjęcia -->
        <TextBlock Grid.Row="0" Text="Zdjęcie:" FontWeight="Bold" Margin="0,0,0,4" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="ImagePathTextBox" Width="300" Height="28" Margin="0,0,8,0" IsReadOnly="True" />
            <Button Content="Wybierz..." Click="SelectImage_Click" Width="80" />
        </StackPanel>

        <!-- Podgląd zdjęcia -->
        <TextBlock Grid.Row="2" Text="Podgląd:" FontWeight="Bold" Margin="0,0,0,4" />
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,12">
            <Image x:Name="ImagePreview" Stretch="Uniform" />
        </Border>

        <!-- Opis -->
        <TextBlock Grid.Row="4" Text="Opis (pod zdjęciem):" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox Grid.Row="4" x:Name="DescriptionTextBox" 
                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,24,0,12" />

        <!-- Rozmiar czcionki opisu -->
        <TextBlock Grid.Row="5" Text="Rozmiar czcionki opisu:" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBox Grid.Row="5" x:Name="DescriptionFontSizeTextBox" Width="80" Height="28" 
                 HorizontalAlignment="Left" Margin="0,24,0,12" />

        <!-- Rozmiar -->
        <TextBlock Grid.Row="6" Text="Rozmiar (szerokość x wysokość):" FontWeight="Bold" Margin="0,0,0,4" />
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,24,0,12">
            <TextBox x:Name="WidthTextBox" Width="80" Height="28" Margin="0,0,8,0" />
            <TextBlock Text=" x " VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="HeightTextBox" Width="80" Height="28" Margin="0,0,8,0" />
            <Button Content="Normalizuj" Click="NormalizeSize_Click" Width="100" Margin="8,0,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK" IsDefault="True" Click="OK_Click" Width="80" Margin="0,0,8,0" />
            <Button Content="Anuluj" IsCancel="True" Width="80" />
        </StackPanel>
    </Grid>
</Window>
